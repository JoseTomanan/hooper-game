# Godot 4
.godot/
/android/
export.cfg
export_presets.cfg

# .NET build output (generated once the C# solution exists)
.mono/
bin/
obj/
*.user

# Godot exported builds
build/

# Godot resource UID sidecar files (auto-generated, not source)
*.uid
# Exception: locomotion.res is a hand-saved AnimationLibrary with no importer,
# so Godot never regenerates its sidecar — unlike .cs/.import-backed resources.
# Player.tscn references it by uid (#140), so this one sidecar IS the only
# backing for that uid and MUST ship, or the library fails to resolve off this
# machine (humanoid stuck in bind pose).
!assets/locomotion.res.uid
# Exception: grid_cutout.gdshader is a hand-authored (non-editor-saved) shader
# (#223) — nothing regenerates this sidecar off this machine either, and
# Main.tscn's ext_resource references it by uid, so it must ship the same way
# locomotion.res.uid does (#153/#223).
!scenes/shaders/grid_cutout.gdshader.uid

# Cross-session handoffs are scratch (in-flight state, not durable docs).
# Keep the folder + its README in the repo so the convention is discoverable,
# but never commit the handoff files themselves.
docs/handoffs/*
!docs/handoffs/README.md

# IDE / OS
.vs/
.vscode/
*.suo
Thumbs.db
.DS_Store
